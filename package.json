{
  "name": "trpc-monorepo",
  "private": true,
  "scripts": {
    "build": "cross-env NODE_ENV=production turbo build",
    "dev": "dotenv -- turbo dev",
    "db:generate": "dotenv -- turbo db:generate",
    "db:migrate": "dotenv -- turbo db:migrate",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo check-types",
    "validate": "pnpm lint && pnpm check-types && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "patchedDependencies": {
      "@octokit/app@15.1.6": "patches/@octokit__app@15.1.6.patch"
    }
  }
}
